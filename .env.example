# Chalk configuration. Copy to .env and adjust.

# SQLite (default, zero setup) or PostgreSQL, e.g.
#   postgresql://chalk:password@localhost:5432/chalk
# For PostgreSQL also switch the provider in prisma/schema.prisma and see
# docs/self-hosting.
DATABASE_URL="file:./chalk.db"

# Optional: publish programs from this instance to a central community hub.
# Register via POST <hub>/api/federation/register to get an API key.
HUB_URL=""
INSTANCE_API_KEY=""

# Optional: seed a demo account (demo@chalk.local / demo-password-123).
# Never enable on a public instance.
# SEED_DEMO="1"
